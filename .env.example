# Canonical site origin for sitemap/robots/OG (no trailing slash)
NEXT_PUBLIC_SITE_URL=

# --- Dashboard auth (required for /dashboard) ---
# Password Cherry types on /dashboard/login
ADMIN_PASSWORD=
# Secret for HMAC-signing the session cookie (any long random string)
# e.g. `openssl rand -hex 32`
ADMIN_SESSION_SECRET=

# --- Publishing (production only) ---
# When all three GITHUB_* below are set, dashboard saves commit the content JSON
# to GitHub, which triggers a Vercel redeploy. Without them:
#   - locally: saves write content/site-content.json directly to disk
#   - on Vercel: dashboard is read-only
# Fine-grained token with "Contents: read & write" on the repo.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Branch to commit to (defaults to "main")
GITHUB_CONTENT_BRANCH=
# Path of the content file in the repo (defaults to "content/site-content.json")
GITHUB_CONTENT_PATH=
